# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-change-this-in-production
BETTER_AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=file:./local.db

# AI Provider Configuration
# Add your API keys below to enable AI-powered PRD generation

# Anthropic Claude (Primary)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (Fallback)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: AI Provider Selection
# Options: "anthropic", "openai", or leave empty for auto-selection
# AI_PROVIDER=anthropic

# Optional: Model Selection (defaults to best available models)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OPENAI_MODEL=gpt-4o

# Mayar Payment Gateway
# Get your credentials from: https://mayar.id/
MAYAR_API_KEY=your-mayar-api-key-here
MAYAR_WEBHOOK_TOKEN=your-mayar-webhook-token-here
MAYAR_MODE=production  # Options: "production" or "sandbox"

# Email Notifications (Resend)
# Get your API key from: https://resend.com/api-keys
EMAIL_PROVIDER=resend  # Options: "resend", "sendgrid", "brevo"
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=onboarding@resend.dev  # Change to your verified domain in production

# Redis Rate Limiting (Optional, for production)
# Leave empty to use in-memory rate limiting (development)
REDIS_URL=redis://localhost:6379  # Or your Redis cloud provider URL (Upstash, Redis Cloud, etc.)

# Analytics & Monitoring (Optional)
# PostHog for product analytics
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry for error monitoring
# SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
